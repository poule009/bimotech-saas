APP_NAME=BimoTech
APP_ENV=testing
APP_KEY=base64:METS_ICI_TA_CLE_APP_KEY_DE_TON_ENV_NORMAL
APP_DEBUG=true
APP_URL=http://localhost

# Base SQLite en mémoire — rien n'est écrit sur disque, tout est isolé
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# Désactiver les emails pendant les tests
MAIL_MAILER=array

# Désactiver les queues (jobs synchrones)
QUEUE_CONNECTION=sync

# Cache en tableau (pas Redis, pas fichier)
CACHE_DRIVER=array
SESSION_DRIVER=array